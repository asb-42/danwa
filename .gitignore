# Profile configurations (may contain API keys, private IPs, user-specific settings)
# NOTE: Use file-level patterns (not directory patterns) so that git can still
#       look inside subdirectories and apply the ! exceptions below.
profiles/agents/*.yaml
profiles/llm/*.yaml
profiles/prompts/**/*.md
# Allow example files (templates for new users) and documentation
!profiles/agents/*example*.yaml
!profiles/llm/*example*.yaml
!profiles/prompts/**/*example*.md
!profiles/prompts/README.md

# Reports & render output
reports/
/output/
*.docx
*.pdf

# Module exports (user-generated ZIP files)
exports/
modules/agent-bundles/

# Environment specific / User config (never commit real credentials)
settings.yaml
config/settings.yaml
config/a2a.json

# Notes (user-specific, not for version control)
notes.txt
docs/notes.txt

