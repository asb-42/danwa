{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Module Manifest",
  "description": "Manifest-Datei für Module (Prompts, Agenten, LLM-Profile, Workflows, Tone-Profiles)",
  "type": "object",
  "required": [
    "schema_version",
    "module_id",
    "name",
    "version",
    "type",
    "files"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0.0"],
      "description": "Version dieses Manifest-Schemas"
    },
    "module_id": {
      "type": "string",
      "pattern": "^danwa-[a-z0-9][a-z0-9.-]*$",
      "description": "Eindeutige Modul-ID, z.B. 'danwa-prompts-base', 'danwa-agents-base'"
    },
    "name": {
      "type": "object",
      "description": "Menschenlesbarer Name pro Sprache",
      "properties": {
        "en": { "type": "string" },
        "de": { "type": "string" }
      },
      "additionalProperties": { "type": "string" }
    },
    "description": {
      "type": "object",
      "description": "Beschreibung pro Sprache",
      "additionalProperties": { "type": "string" }
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantisches Version des Moduls"
    },
    "type": {
      "type": "string",
      "enum": [
        "argumentation-pattern",
        "agent-persona",
        "llm-profile",
        "workflow-template",
        "tone-profile",
        "workflow-variant",
        "role-type",
        "bundle"
      ]
    },
    "category": {
      "type": "string",
      "description": "Kategorie für die UI-Gruppierung",
      "enum": [
        "prompts",
        "agents",
        "llm-profiles",
        "workflows",
        "workflow-variants",
        "tone-profiles",
        "role-types",
        "bundles"
      ]
    },
    "author": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "contact": { "type": "string" },
        "org": { "type": "string" }
      }
    },
    "license": {
      "type": "string",
      "description": "Lizenz, z.B. 'CC-BY-4.0', 'MIT'"
    },
    "dependencies": {
      "type": "object",
      "description": "Abhängigkeiten zu anderen Modulen oder Core",
      "propertyNames": {
        "type": "string",
        "pattern": "^danwa-[a-z0-9][a-z0-9.-]*$|^danwa-core$"
      },
      "additionalProperties": {
        "type": "string",
        "pattern": "^>=?[0-9]+\\.[0-9]+\\.[0-9]+$"
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Freie Schlagworte für Suche/Kategorisierung"
    },
    "language": {
      "type": "string",
      "description": "Quellsprache des Moduls (SSOT-Sprache)",
      "enum": ["en"]
    },
    "checksum": {
      "type": "string",
      "description": "SHA-256-Prüfsumme aller Dateien im Modul (base64-kodiert)",
      "pattern": "^[a-f0-9]{64}$"
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "description": "Liste aller Dateien im Modul",
      "items": {
        "type": "object",
        "required": ["path", "format", "checksum"],
        "properties": {
          "path": {
            "type": "string",
            "description": "Relativer Pfad innerhalb des Moduls, z.B. 'prompts/default/strategist.md'"
          },
          "format": {
            "type": "string",
            "enum": ["markdown", "yaml", "json"],
            "description": "Dateiformat"
          },
          "checksum": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "role_type_id": {
            "type": "string",
            "description": "Zugehörige funktionale Rolle (bei Prompts/Personas)"
          },
          "mode": {
            "type": "string",
            "description": "Zugehöriger formatorischer Modus (optional)"
          },
          "language": {
            "type": "string",
            "description": "Sprache der Datei (bei Prompts)"
          },
          "subtype": {
            "type": "string",
            "description": "Untertyp wie 'default', 'kantian', 'hegelian' etc."
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
