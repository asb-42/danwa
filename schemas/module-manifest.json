{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Module Manifest",
  "description": "Manifest-Datei für Module (Prompts, Agenten, LLM-Profile, Workflows, Tone-Profiles)",
  "type": "object",
  "required": [
    "schema_version",
    "module_id",
    "name",
    "version",
    "type"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0.0", "2.0.0", "3.0.0"],
      "description": "Version dieses Manifest-Schemas"
    },
    "module_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9.-]*$",
      "description": "Eindeutige Modul-ID, z.B. 'danwa-prompts-base', 'agent-critic-default'"
    },
    "name": {
      "type": "object",
      "description": "Menschenlesbarer Name pro Sprache",
      "properties": {
        "en": { "type": "string" },
        "de": { "type": "string" }
      },
      "additionalProperties": { "type": "string" }
    },
    "description": {
      "type": "object",
      "description": "Beschreibung pro Sprache",
      "additionalProperties": { "type": "string" }
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantisches Version des Moduls"
    },
    "type": {
      "type": "string",
      "enum": [
        "argumentation-pattern",
        "agent-persona",
        "llm-profile",
        "workflow-template",
        "tone-profile",
        "workflow-variant",
        "role-type",
        "prompt-variant",
        "prompt-modifier",
        "kitsune-assistant",
        "bundle",
        "language-pack",
        "agent-core"
      ]
    },
    "category": {
      "type": "string",
      "description": "Kategorie für die UI-Gruppierung",
      "enum": [
        "prompts",
        "prompt-modifiers",
        "agents",
        "llm-profiles",
        "workflows",
        "workflow-variants",
        "tone-profiles",
        "role-types",
        "kitsune",
        "bundles",
        "translations"
      ]
    },
    "author": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "contact": { "type": "string" },
        "org": { "type": "string" }
      }
    },
    "license": {
      "type": "string",
      "description": "Lizenz, z.B. 'CC-BY-4.0', 'MIT'"
    },
    "dependencies": {
      "type": "object",
      "description": "Abhängigkeiten zu anderen Modulen mit semver-Constraints (z.B. '>=2.0.0', '^1.0.0')",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[><=!~^]+[0-9]+\\.[0-9]+\\.[0-9]+$|^\\^[0-9]+\\.[0-9]+\\.[0-9]+$|^~[0-9]+\\.[0-9]+\\.[0-9]+$"
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Freie Schlagworte für Suche/Kategorisierung"
    },
    "language": {
      "type": "string",
      "description": "Quellsprache des Moduls (SSOT-Sprache). ISO 639-1 code, z.B. 'en', 'de', 'ar'."
    },
    "checksum": {
      "type": "string",
      "description": "SHA-256 der Inhaltsdateien (ohne manifest.json). Dient als Modul-Integritätscheck in module_registry.",
      "pattern": "^[a-f0-9]{64}$"
    },
    "profile_file": {
      "type": "string",
      "description": "Name der Profildatei (v2/v3 Format), z.B. 'profile.yaml', 'persona.md'"
    },
    "profile_format": {
      "type": "string",
      "enum": ["yaml", "json", "markdown"],
      "description": "Format der Profildatei"
    },
    "files": {
      "type": "array",
      "description": "Liste aller Dateien im Modul (legacy v1 bundle format)",
      "items": {
        "type": "object",
        "required": ["path", "format", "checksum"],
        "properties": {
          "path": {
            "type": "string",
            "description": "Relativer Pfad innerhalb des Moduls"
          },
          "format": {
            "type": "string",
            "enum": ["markdown", "yaml", "json"],
            "description": "Dateiformat"
          },
          "checksum": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$",
            "description": "SHA-256 dieser einzelnen Datei"
          },
          "role_type_id": {
            "type": "string",
            "description": "Zugehörige funktionale Rolle"
          },
          "mode": {
            "type": "string",
            "description": "Zugehöriger formatorischer Modus"
          },
          "language": {
            "type": "string",
            "description": "Sprache der Datei"
          },
          "subtype": {
            "type": "string",
            "description": "Untertyp wie 'default', 'kantian', 'hegelian'"
          }
        }
      }
    },
    "compatibility": {
      "type": "object",
      "description": "Kompatibilitätsangaben für Danwa-Versionen",
      "properties": {
        "danwa_min_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Mindestens erforderliche Danwa-Version"
        },
        "danwa_max_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Maximal unterstützte Danwa-Version (null = unbegrenzt)"
        }
      }
    },
    "repository": {
      "type": "object",
      "description": "Quell-Repository des Moduls",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["github"],
          "description": "Repository-Typ"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Repository-URL"
        },
        "ref": {
          "type": "string",
          "description": "Git-Ref (Branch, Tag, Commit) für die Version"
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
