import asyncio
import logging
import json
import re
from typing import List, Dict
from duckduckgo_search import AsyncDDGS

logger = logging.getLogger(__name__)

class WebSearchTool:
    def __init__(self, max_results: int = 5, region: str = "de-de", time_filter: str = "y"):
        self.max_results = max_results
        self.region = region
        self.time_filter = time_filter

    async def search(self, query: str) -> List[Dict]:
        results = []
        try:
            async with AsyncDDGS() as ddgs:
                async for r in ddgs.text(
                    query, 
                    region=self.region, 
                    max_results=self.max_results, 
                    timelimit=self.time_filter
                ):
                    results.append({
                        "title": r.get("title", ""),
                        "url": r.get("href", ""),
                        "snippet": r.get("body", ""),
                        "date": r.get("date", "")
                    })
        except Exception as e:
            logger.warning(f"Search failed for '{query}': {e}")
        return results

    @staticmethod
    def extract_json_list(text: str) -> List[str]:
        """Robust parser for LLM-wrapped JSON arrays"""
        match = re.search(r'\[.*\]', text, re.DOTALL)
        if not match: return []
        try:
            return json.loads(match.group(0))
        except json.JSONDecodeError:
            return []