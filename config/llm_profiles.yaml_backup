profiles:
  local_lm_studio:
    model: "qwen2.5-7b"
    base_url: "http://localhost:1234/v1"
    api_key: "sk-dummy"
    params: { temperature: 0.5, top_p: 0.9, seed: 42, max_tokens: 4000 }

  openrouter_claude:
    model: "anthropic/claude-3-5-sonnet"
    base_url: "https://openrouter.ai/api/v1"
    api_key_env: "OPENROUTER_KEY"
    params: { temperature: 0.6, top_p: 0.95, seed: null, max_tokens: 8000 }

defaults:
  max_rounds: 3
  consensus_threshold: 0.75
  strict_mode: true