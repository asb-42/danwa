[Unit]
Description=Run Debate Agent Retention Cleanup
[Service]
Type=oneshot
WorkingDirectory=%h/projects/debate-agent
Environment="PATH=%h/.local/bin:%h/projects/debate-agent/.venv/bin"
ExecStart=%h/.local/bin/uv run python -c "from src.core.privacy import PrivacyGuard; PrivacyGuard(retention_days=90).enforce_retention()"