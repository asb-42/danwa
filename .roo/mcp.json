{
	"mcpServers": {
		"react-flow": {
			"command": "npx",
			"args": [
				"@yeshsurya/react-flow-mcp-server"
			],
			"alwaysAllow": [
				"list_react_flow_hooks",
				"list_react_flow_utilities",
				"list_react_flow_types",
				"list_react_flow_components",
				"search_react_flow_examples",
				"get_react_flow_docs"
			]
		}
	}
}